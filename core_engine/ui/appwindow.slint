export component AppWindow inherits Window {
    title: "Real-Time Microscopy";
    width: 1280px;
    height: 720px;
    background: black;

    in property <image> video-frame;

    VerticalLayout {
        Image {
            source: video-frame;
            width: 100%;
            height: 100%;
            image-fit: contain;
        }
    }
}
